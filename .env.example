# Copie para `.env` e preencha com seus valores reais.
# Essas variáveis são LIDAS no momento do `npm run build` e EMBUTIDAS no
# JavaScript em dist/. Nunca commite o .env de verdade.

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ.sua_chave_anon...

# Opcional: URL pra onde o endpoint /api/recibo/pdf deve apontar no dev.
# (apenas se você for rodar `node server.js` em paralelo ao vite.)
# VITE_API_TARGET=http://localhost:3000
