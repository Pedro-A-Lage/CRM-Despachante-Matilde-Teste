{
  "manifest_version": 3,
  "name": "Matilde CRM - Extensão Detran/Cidadão MG",
  "version": "2.1",
  "description": "Automação de consultas e captura de PDFs para o Matilde CRM.",
  "permissions": [
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "*://*.detran.mg.gov.br/*",
    "*://*.transito.mg.gov.br/*",
    "*://*.cidadao.mg.gov.br/*",
    "*://localhost/*",
    "*://*.matildecrm.com/*",
    "*://*.despachantematilde.com/*",
    "*://*.despachantematilde.com.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.detran.mg.gov.br/*",
        "*://*.transito.mg.gov.br/*"
      ],
      "js": ["content_detran.js"]
    },
    {
      "matches": [
        "*://localhost:5173/*",
        "*://localhost:3000/*",
        "*://*.matildecrm.com/*",
        "*://*.despachantematilde.com/*",
        "*://*.despachantematilde.com.br/*"
      ],
      "js": ["crm_bridge.js"]
    }
  ]
}
